# Copia este archivo a ".env" y cambia los valores antes de desplegar

# Puerto del servidor
PORT=3000

# URL publica donde va a vivir la app (usada para generar los QR)
# Ejemplo produccion: https://menu.mirestaurante.com
BASE_URL=http://localhost:3000

# Secreto para firmar tokens de sesion (JWT). CAMBIALO por uno largo y aleatorio.
# Puedes generar uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO_Y_UNICO

# Duracion de la sesion de admin/cocina
JWT_EXPIRES_IN=12h

# Entorno
NODE_ENV=production

# Origenes permitidos para CORS, separados por coma (deja vacio para permitir el mismo origen solamente)
CORS_ORIGINS=

# Limite de pedidos por mesa en la ventana de tiempo (anti-spam / picos)
ORDER_RATE_LIMIT_MAX=5
ORDER_RATE_LIMIT_WINDOW_MIN=10
